#!/bin/sh
# Kiln: classify an image on the RK3576 NPU (MobileNet via librknnrt / RKNN).
# Config-driven -- model, labels, top-N, NPU core mask and priority come from
# /etc/kiln/config.ini (edit by hand).
# Usage: kiln-vision [image.jpg]   (old form: kiln-vision <model.rknn> <image> [labels])
export LD_LIBRARY_PATH=/usr/lib

# ensure the vendor rknpu driver is loaded (same as kiln-chat).
if ! grep -q '^rknpu' /proc/modules 2>/dev/null; then
	KO="$(find "/lib/modules/$(uname -r)" -name 'rknpu.ko*' 2>/dev/null | head -1)"
	[ "$(id -u)" -eq 0 ] && S= || S=sudo
	echo "kiln-vision: loading rknpu (needs root) ..."
	$S modprobe rknpu 2>/dev/null || $S insmod "$KO" 2>/dev/null
	sleep 1
fi
if ! grep -q '^rknpu' /proc/modules 2>/dev/null; then
	echo "kiln-vision: rknpu not loaded. Load it as root first:  sudo modprobe rknpu"
	exit 1
fi

# preflight the vision model (config-driven), unless a model was given on the CLI
# (old form: kiln-vision <model.rknn> <image> [labels]). Vision has no fallback, so
# a missing .rknn is fatal -- point at kiln-config / VISION.md instead of a cryptic
# "cannot read model" from the binary.
case "${1:-}" in
*.rknn) : ;;   # explicit model given -- skip the config preflight
*)
	CONF="${KILN_CONFIG:-/etc/kiln/config.ini}"
	VIS_MODEL=$(awk '/^[ \t]*\[/{s=$0} s ~ /^[ \t]*\[vision\]/ && /^[ \t]*model[ \t]*=/{sub(/^[^=]*=/,"");sub(/[ \t]#.*/,"");gsub(/^[ \t]+|[ \t]+$/,"");print;exit}' "$CONF" 2>/dev/null)
	if [ -z "$VIS_MODEL" ] || [ ! -f "$VIS_MODEL" ]; then
		echo "kiln-vision: no vision model found (config [vision] model = '${VIS_MODEL:-unset}')."
		echo "  Build one on the board -- no x86 host, no scp:"
		echo "      sudo kiln-convert mobilenet --set-active    # image classifier"
		echo "      sudo kiln-convert yolov8n  --set-active    # object detector (YOLO)"
		echo "  or drop your own .rknn in /opt/models and pick it in: sudo kiln-config -> Vision"
		exit 1
	fi
	;;
esac

echo "=== Kiln RK3576 NPU vision (MobileNet, librknnrt) ==="
exec rknn_mobilenet "$@"
