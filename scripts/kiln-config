#!/bin/sh
# kiln-config -- a whiptail (fallback: dialog) TUI front-end to /etc/kiln/config.ini
# and the kiln tools, modelled on armbian-config. It is a FRONT-END: config.ini
# stays the hand-editable single source of truth, and every write goes through an
# in-place editor that preserves comments and unknown fields (never a full rewrite).
#
# Design rules honored here:
#   * <Save> writes, <Back> discards -- nothing is persisted until you confirm.
#   * model pickers SCAN /opt/models (no path typing); enums are radio lists.
#   * vision defaults to CLASSIFICATION; task=detect is EXPERIMENTAL (unverified) and
#     labelled as such -- never presented as a working feature.
#   * needs root to edit /etc/kiln/config.ini and to read dmesg -> re-exec via sudo.
#
# Pages: Status & Diagnostics, LLM Settings, Vision Settings, Server, Models, Advanced.

CONF="${KILN_CONFIG:-/etc/kiln/config.ini}"
MODELS_DIR="${KILN_MODELS_DIR:-/opt/models}"

# whiptail, or dialog as a fallback
UI=whiptail
command -v whiptail >/dev/null 2>&1 || UI=dialog
command -v "$UI" >/dev/null 2>&1 || { echo "kiln-config needs 'whiptail' (or 'dialog'): sudo apt install whiptail" >&2; exit 1; }

# Root for editing $CONF (root-owned) and for kiln-doctor's dmesg read. Re-exec via
# sudo, forwarding KILN_CONFIG so a custom path survives the privilege change.
if [ "$(id -u)" -ne 0 ]; then
	command -v sudo >/dev/null 2>&1 || { echo "kiln-config must run as root (to edit $CONF)." >&2; exit 1; }
	exec sudo KILN_CONFIG="$CONF" KILN_MODELS_DIR="$MODELS_DIR" "$0" "$@"
fi

# ---------------------------------------------------------------------------
# INI helpers -- the same "present -> replace in place / absent -> append to the
# CORRECT section end" logic that avoids the silent no-op of a naive sed. Values
# are written as awk literals, so /, &, # in a system_prompt can't corrupt the file.
# (Round-trips a hand-edited config: comments + unknown fields are preserved.)
# ---------------------------------------------------------------------------
kiln_ini_set() {
	f=$1; sec=$2; key=$3; val=$4
	[ -f "$f" ] || : > "$f" || return 1
	t=$(mktemp) || return 1
	awk -v section="$sec" -v key="$key" -v value="$val" '
		BEGIN { in_t=0; done=0 }
		/^[ \t]*\[.*\][ \t]*$/ {
			if (in_t && !done) { print key " = " value; done=1 }
			h=$0; sub(/^[ \t]*\[/,"",h); sub(/\][ \t]*$/,"",h); in_t=(h==section); print; next
		}
		in_t && !done {
			if (match($0,/^[ \t]*[^=]*=/)) { n=substr($0,1,RLENGTH-1); gsub(/^[ \t]+|[ \t]+$/,"",n);
				if (n==key) { print key " = " value; done=1; next } }
		}
		{ print }
		END { if (!done) { if (in_t) print key " = " value;
			else { if (NR>0) print ""; print "[" section "]"; print key " = " value } } }
	' "$f" > "$t" || { rm -f "$t"; return 1; }
	cat "$t" > "$f" && rm -f "$t"
}
kiln_ini_get() {
	[ -f "$1" ] || return 0
	awk -v s="$2" -v k="$3" '
		/^[ \t]*\[.*\][ \t]*$/ { h=$0; sub(/^[ \t]*\[/,"",h); sub(/\][ \t]*$/,"",h); t=(h==s); next }
		t { if (match($0,/^[ \t]*[^=]*=/)) { n=substr($0,1,RLENGTH-1); gsub(/^[ \t]+|[ \t]+$/,"",n);
			if (n==k) { v=substr($0,RLENGTH+1); sub(/[ \t]#.*$/,"",v); gsub(/^[ \t]+|[ \t]+$/,"",v); print v; exit } } }
	' "$1"
}

# ---------------------------------------------------------------------------
# whiptail wrappers. ALWAYS render the widget to /dev/tty and return the choice on
# stdout. This makes them work even when the wrapper is itself inside a $(...)
# capture (e.g. a picker that pops a msgbox): the box still draws on the terminal,
# never into the captured stream. (whiptail prints the choice on stderr, so
# `2>&1 1>/dev/tty` sends the widget to the tty and the choice to the caller's fd1.)
# ---------------------------------------------------------------------------
# Persistent top bar (armbian-config style). Every dialog carries it.
BT="Kiln  ·  LLM + vision on the RK3576 NPU  ·  $CONF"
msg()   { $UI --backtitle "$BT" --title "$TITLE" --msgbox "$1" "${2:-14}" "${3:-74}" 1>/dev/tty; }
yesno() { $UI --backtitle "$BT" --title "$TITLE" --yesno "$1" "${2:-10}" "${3:-70}" 1>/dev/tty; }   # returns 0=yes
input() { $UI --backtitle "$BT" --title "$TITLE" --inputbox "$1" 10 70 "$2" 3>&1 1>/dev/tty 2>&3 3>&-; }
# menu TITLE TEXT tag item ...  -- the first arg becomes the window --title, so each
# page reads as its own screen. '--' before the tag/item list so whiptail/popt never
# mis-parses an item starting with '-' (e.g. -1, or an odd filename) as an option --
# that error would otherwise be swallowed by the caller's `|| break` (TUI "won't open").
menu()  { mt=$1; mp=$2; shift 2; $UI --backtitle "$BT" --title "$mt" --menu "$mp" 20 78 12 -- "$@" 3>&1 1>/dev/tty 2>&3 3>&-; }

short() { s=$1; [ -z "$s" ] && { echo "(unset)"; return; }; b=$(basename "$s" 2>/dev/null); echo "${b:-$s}"; }

# edit_opt VARNAME "prompt" -- inputbox that distinguishes Cancel (keep old) from
# clearing to empty (a valid value for e.g. system_prompt). Sets MOD on a change.
edit_opt() {
	eval "old=\$$1"
	newv=$(input "$2" "$old") || return          # Cancel -> keep old
	[ "$newv" != "$old" ] && { eval "$1=\$newv"; MOD=1; }
}

# radio_pick "prompt" "current" val1 val2 ...  -> echoes the chosen value (or current on cancel)
radio_pick() {
	rp=$1; cur=$2; shift 2
	set -- $(for v in "$@"; do if [ "$v" = "$cur" ]; then printf '%s . ON ' "$v"; else printf '%s . OFF ' "$v"; fi; done)
	sel=$($UI --backtitle "$BT" --title "$TITLE" --radiolist "$rp" 14 64 6 -- "$@" 3>&1 1>/dev/tty 2>&3 3>&-) || { echo "$cur"; return; }
	[ -n "$sel" ] && echo "$sel" || echo "$cur"
}

# model_pick EXT current  -> scan $MODELS_DIR/*.EXT, present a menu, echo chosen path.
# Shows clean basenames (+ size), not full paths; reconstructs the path on choice.
model_pick() {
	ext=$1; cur=$2
	set --
	for f in "$MODELS_DIR"/*."$ext"; do
		[ -f "$f" ] || continue
		sz=$(du -h "$f" 2>/dev/null | cut -f1)
		set -- "$@" "$(basename "$f")" "${sz:-?}"
	done
	if [ "$#" -eq 0 ]; then
		msg "No *.$ext models found in $MODELS_DIR.\n\nDrop one there (see Models page, or VISION.md), then come back."
		echo "$cur"; return
	fi
	set -- "$@" "(type a path)" "enter a full path by hand"
	[ -n "$cur" ] && set -- "$@" "(unset)" "clear this model"
	sel=$(menu "Pick a model" "current: $(short "$cur")     ($MODELS_DIR)" "$@") || { echo "$cur"; return; }
	case "$sel" in
		"(type a path)") input "Full path to the model file:" "$cur" ;;
		"(unset)")       echo "" ;;
		*)               echo "$MODELS_DIR/$sel" ;;   # basename -> full path
	esac
}

# ---------------------------------------------------------------------------
# 1. Status & Diagnostics
# ---------------------------------------------------------------------------
status_page() {
	if command -v kiln-doctor >/dev/null 2>&1; then rep=$(kiln-doctor 2>&1); else rep=$(sh "$(dirname "$0")/kiln-doctor" 2>&1 || echo "kiln-doctor not found"); fi
	# strip ANSI so whiptail shows it cleanly
	rep=$(printf '%s' "$rep" | sed 's/\x1b\[[0-9;]*m//g')
	$UI --backtitle "$BT" --title "Status & Diagnostics" --scrolltext --yes-button "Re-run" --no-button "Back" \
		--yesno "$rep" 24 82 1>/dev/tty && status_page
}

# ---------------------------------------------------------------------------
# 2. LLM Settings  ([llm])
# ---------------------------------------------------------------------------
llm_page() {
	g() { kiln_ini_get "$CONF" llm "$1"; }
	v_model=$(g model); v_temp=$(g temperature); v_topk=$(g top_k); v_topp=$(g top_p)
	v_newtok=$(g max_new_tokens); v_ctx=$(g max_context_len); v_rep=$(g repeat_penalty)
	v_keep=$(g keep_history); v_sys=$(g system_prompt)
	MOD=0
	while :; do
		sel=$(menu "LLM Settings ([llm])" "$([ $MOD = 1 ] && echo '* unsaved changes *' || echo "editing $CONF")" \
			model          "$(short "$v_model")" \
			temperature    "$v_temp" \
			top_k          "$v_topk" \
			top_p          "$v_topp" \
			max_new_tokens "$v_newtok" \
			max_context_len "$v_ctx" \
			repeat_penalty "$v_rep" \
			keep_history   "$v_keep (1=multi-turn,0=single)" \
			system_prompt  "$(short_sys "$v_sys")" \
			SAVE           "write changes to $CONF" \
			BACK           "discard & return") || { llm_maybe_back && return; continue; }
		case "$sel" in
			model)          n=$(model_pick rkllm "$v_model"); [ "$n" != "$v_model" ] && { v_model=$n; MOD=1; } ;;
			temperature)    n=$(input "Temperature 0.0-2.0 (sampling randomness; applies next kiln-chat):" "$v_temp"); setmod v_temp "$n" ;;
			top_k)          n=$(input "top_k (1 = greedy; most coherent on the 1.5B):" "$v_topk"); setmod v_topk "$n" ;;
			top_p)          n=$(input "top_p 0.0-1.0 (nucleus sampling):" "$v_topp"); setmod v_topp "$n" ;;
			max_new_tokens) n=$(input "max_new_tokens (reply length cap):" "$v_newtok"); setmod v_newtok "$n" ;;
			max_context_len) n=$(input "max_context_len (KV window; needs model reload):" "$v_ctx"); setmod v_ctx "$n" ;;
			repeat_penalty) n=$(input "repeat_penalty (>1 discourages loops, e.g. 1.3):" "$v_rep"); setmod v_rep "$n" ;;
			keep_history)   n=$(radio_pick "Multi-turn KV history?" "$v_keep" 1 0); setmod v_keep "$n" ;;
			system_prompt)  edit_opt v_sys "System prompt (one line; empty = none):" ;;
			SAVE)
				kiln_ini_set "$CONF" llm model "$v_model"; kiln_ini_set "$CONF" llm temperature "$v_temp"
				kiln_ini_set "$CONF" llm top_k "$v_topk"; kiln_ini_set "$CONF" llm top_p "$v_topp"
				kiln_ini_set "$CONF" llm max_new_tokens "$v_newtok"; kiln_ini_set "$CONF" llm max_context_len "$v_ctx"
				kiln_ini_set "$CONF" llm repeat_penalty "$v_rep"; kiln_ini_set "$CONF" llm keep_history "$v_keep"
				kiln_ini_set "$CONF" llm system_prompt "$v_sys"
				MOD=0; msg "Saved to $CONF.\n\nMost LLM knobs apply the next time you start kiln-chat / kiln-serve." ;;
			BACK|"") llm_maybe_back && return ;;
		esac
	done
}
llm_maybe_back() { [ "$MOD" = 1 ] || return 0; yesno "Discard unsaved LLM changes?" && return 0; return 1; }
short_sys() { [ -z "$1" ] && echo "(none)" || echo "$(printf '%.24s' "$1")..."; }
setmod() { eval "cur=\$$1"; [ -n "$2" ] && [ "$2" != "$cur" ] && { eval "$1=\$2"; MOD=1; }; }

# ---------------------------------------------------------------------------
# 3. Vision Settings ([vision])  -- CLASSIFICATION ONLY
# ---------------------------------------------------------------------------
vision_page() {
	g() { kiln_ini_get "$CONF" vision "$1"; }
	v_model=$(g model); v_labels=$(g labels); v_topn=$(g top_n)
	v_core=$(g core_mask); v_prio=$(g priority)
	v_task=$(g task); [ -n "$v_task" ] || v_task=classify
	v_det=$(g detector); [ -n "$v_det" ] || v_det=auto
	v_conf=$(g conf_threshold); [ -n "$v_conf" ] || v_conf=0.25
	v_nms=$(g nms_iou); [ -n "$v_nms" ] || v_nms=0.45
	MOD=0
	while :; do
		sel=$(menu "Vision Settings ([vision])" "$([ $MOD = 1 ] && echo '* unsaved changes *' || echo "task=$v_task (detect = EXPERIMENTAL, unverified)")" \
			task       "$v_task  (classify | detect=EXPERIMENTAL)" \
			model      "$(short "$v_model")" \
			labels     "$(short "$v_labels")" \
			top_n      "$v_topn  (classify)" \
			detector   "$v_det  (detect family)" \
			conf       "$v_conf  (detect score threshold)" \
			nms_iou    "$v_nms  (detect NMS IoU)" \
			core_mask  "$v_core" \
			priority   "$v_prio" \
			SAVE       "write changes to $CONF" \
			BACK       "discard & return") || { vis_maybe_back && return; continue; }
		case "$sel" in
			task)
				n=$(radio_pick "Vision task:" "$v_task" classify detect)
				if [ "$n" = detect ] && [ "$v_task" != detect ]; then
					msg "task=detect is EXPERIMENTAL (YOLOv8/11) and UNVERIFIED on hardware -- boxes may be wrong. You supply a YOLOv8/11 .rknn (Ultralytics YOLO is AGPL-3.0; YOLOX is Apache-2.0). See VISION.md."
				fi
				setmod v_task "$n" ;;
			model)
				case "$v_task" in
					detect) msg "Pick a YOLOv8/11 detection .rknn (EXPERIMENTAL). Convert one with rknn-toolkit2 2.3.2; see VISION.md." ;;
					*)      msg "Classification: pick a classification .rknn (e.g. MobileNet). Detection is a separate task (set task=detect)." ;;
				esac
				n=$(model_pick rknn "$v_model"); [ "$n" != "$v_model" ] && { v_model=$n; MOD=1; } ;;
			labels)    edit_opt v_labels "Labels file (one per line; ImageNet-1000 for classify, COCO-80 for detect):" ;;
			top_n)     n=$(input "How many top classes to print (classify):" "$v_topn"); setmod v_topn "$n" ;;
			detector)  n=$(radio_pick "Detection family (auto detects from output shapes):" "$v_det" auto yolov8 yolov5 yolox); setmod v_det "$n" ;;
			conf)      n=$(input "Detection score threshold 0-1 (task=detect):" "$v_conf"); setmod v_conf "$n" ;;
			nms_iou)   n=$(input "Detection NMS IoU threshold 0-1 (task=detect):" "$v_nms"); setmod v_nms "$n" ;;
			core_mask) n=$(radio_pick "NPU core mask (RK3576 has 2 cores):" "$v_core" auto 0 1 0_1); setmod v_core "$n" ;;
			priority)  n=$(radio_pick "NPU scheduling priority:" "$v_prio" high medium low); setmod v_prio "$n" ;;
			SAVE)
				kiln_ini_set "$CONF" vision model "$v_model"; kiln_ini_set "$CONF" vision labels "$v_labels"
				kiln_ini_set "$CONF" vision top_n "$v_topn"; kiln_ini_set "$CONF" vision core_mask "$v_core"
				kiln_ini_set "$CONF" vision priority "$v_prio"; kiln_ini_set "$CONF" vision task "$v_task"
				kiln_ini_set "$CONF" vision detector "$v_det"
				kiln_ini_set "$CONF" vision conf_threshold "$v_conf"; kiln_ini_set "$CONF" vision nms_iou "$v_nms"
				MOD=0; msg "Saved to $CONF.\n\nApplies the next time you run kiln-vision / kiln-serve." ;;
			BACK|"") vis_maybe_back && return ;;
		esac
	done
}
vis_maybe_back() { [ "$MOD" = 1 ] || return 0; yesno "Discard unsaved vision changes?" && return 0; return 1; }

# ---------------------------------------------------------------------------
# 4. Server ([server] + systemd control of kiln-serve)
# ---------------------------------------------------------------------------
server_page() {
	g() { kiln_ini_get "$CONF" server "$1"; }
	v_host=$(g host); v_port=$(g port); MOD=0
	[ -n "$v_host" ] || v_host=0.0.0.0
	[ -n "$v_port" ] || v_port=8080
	while :; do
		st=$(systemctl is-active kiln-serve 2>/dev/null || echo "not-installed")
		en=$(systemctl is-enabled kiln-serve 2>/dev/null || echo "-")
		sel=$(menu "Server ([server])" "kiln-serve: $st / $en $([ "$MOD" = 1 ] && echo '     * unsaved changes *')" \
			host    "$v_host" \
			port    "$v_port" \
			service "start / stop / enable kiln-serve ->" \
			SAVE    "write host/port to $CONF" \
			BACK    "discard & return") || { srv_maybe_back && return; continue; }
		case "$sel" in
			host)    edit_opt v_host "Listen host (0.0.0.0 = all interfaces):" ;;
			port)    n=$(input "Port (e.g. 8080):" "$v_port"); setmod v_port "$n" ;;
			service) service_menu ;;
			SAVE)    kiln_ini_set "$CONF" server host "$v_host"; kiln_ini_set "$CONF" server port "$v_port"
			         MOD=0; msg "Saved to $CONF.\n\nRestart kiln-serve to apply: Server -> service -> restart." ;;
			BACK|"") srv_maybe_back && return ;;
		esac
	done
}
srv_maybe_back() { [ "$MOD" = 1 ] || return 0; yesno "Discard unsaved server changes?" && return 0; return 1; }
service_menu() {
	command -v systemctl >/dev/null 2>&1 || { msg "no systemd here."; return; }
	sel=$(menu "kiln-serve service" "OpenAI-compatible API server (needs an LLM model)" \
		start   "start now" \
		stop    "stop" \
		restart "restart (apply config changes)" \
		enable  "enable + start at boot" \
		disable "disable at boot" \
		status  "show status") || return
	case "$sel" in
		start|stop|restart|disable) out=$(systemctl "$sel" kiln-serve 2>&1); msg "systemctl $sel kiln-serve:\n\n${out:-done}" ;;
		enable)  out=$(systemctl enable --now kiln-serve 2>&1); msg "systemctl enable --now kiln-serve:\n\n${out:-done}" ;;
		status)  out=$(systemctl status kiln-serve --no-pager 2>&1 | head -n 18); msg "$out" 22 90 ;;
	esac
}

# ---------------------------------------------------------------------------
# 5. Models -- YOU supply models (like the vendor stack). List / set / add / remove.
# ---------------------------------------------------------------------------
models_page() {
	while :; do
		llm=$(kiln_ini_get "$CONF" llm model); vis=$(kiln_ini_get "$CONF" vision model)
		sel=$(menu "Models ($MODELS_DIR)" "LLM: $(short "$llm")    Vision: $(short "$vis")" \
			setllm "set the active LLM model   ([llm] model)" \
			setvis "set the active vision model ([vision] model)" \
			list   "list + inspect installed models (sizes, versions)" \
			add    "add a model from a path (copy into $MODELS_DIR)" \
			remove "remove a model file" \
			guide  "how to get / convert models" \
			BACK   "back") || return
		case "$sel" in
			setllm) n=$(model_pick rkllm "$llm"); [ "$n" != "$llm" ] && { kiln_ini_set "$CONF" llm model "$n"; msg "[llm] model = ${n:-(unset)}"; } ;;
			setvis) msg "Vision is CLASSIFICATION-ONLY (top-N labels). Detection / YOLO is not supported -- pick a classification .rknn (e.g. MobileNet)."
			        n=$(model_pick rknn "$vis"); [ "$n" != "$vis" ] && { kiln_ini_set "$CONF" vision model "$n"; msg "[vision] model = ${n:-(unset)}"; } ;;
			list)   models_list ;;
			add)    models_add ;;
			remove) models_remove ;;
			guide)  msg "Kiln doesn't ship models -- you supply them, same as the vendor stack.\n\nLLM: put a *-rk3576-w4a16.rkllm in $MODELS_DIR (must match librkllmrt 1.2.0). kiln-chat auto-finds any .rkllm there.\n\nVision: convert a MobileNet .rknn with rknn-toolkit2 2.3.2 -- ON THE BOARD (aarch64) or an x86 host, see VISION.md -- and put it in $MODELS_DIR. Classification only." 18 84 ;;
			BACK|"") return ;;
		esac
	done
}
models_list() {
	t="Installed in $MODELS_DIR:\n\n"; found=0
	for f in "$MODELS_DIR"/*.rkllm "$MODELS_DIR"/*.rknn; do
		[ -f "$f" ] || continue; found=1
		sz=$(du -h "$f" 2>/dev/null | cut -f1)
		ex=""
		case "$f" in *.rknn) rv=$(strings "$f" 2>/dev/null | grep -oE '"version":"[0-9.]+"' | head -1 | grep -oE '[0-9]+\.[0-9]+\.[0-9]+'); [ -n "$rv" ] && ex="  toolkit $rv" ;; esac
		t="$t  $(basename "$f")   [$sz]$ex\n"
	done
	[ "$found" = 0 ] && t="${t}  (none -- put *.rkllm / *.rknn here)"
	t="$t\n\nRuntimes: librkllmrt 1.2.0, librknnrt 2.3.x -- models must match."
	msg "$t" 20 84
}
models_add() {
	p=$(input "Full path to a .rkllm / .rknn to copy into $MODELS_DIR:" "") || return
	[ -n "$p" ] || return
	[ -f "$p" ] || { msg "Not a file: $p"; return; }
	case "$p" in *.rkllm|*.rknn) : ;; *) yesno "That isn't a .rkllm/.rknn. Copy anyway?" || return ;; esac
	mkdir -p "$MODELS_DIR"
	if cp "$p" "$MODELS_DIR/"; then msg "Copied $(basename "$p") -> $MODELS_DIR"; else msg "Copy failed (permissions?)."; fi
}
models_remove() {
	set --
	for f in "$MODELS_DIR"/*.rkllm "$MODELS_DIR"/*.rknn; do [ -f "$f" ] && set -- "$@" "$(basename "$f")" ""; done
	[ "$#" -eq 0 ] && { msg "No models in $MODELS_DIR."; return; }
	sel=$(menu "Remove a model" "delete a file from $MODELS_DIR (cannot be undone)" "$@") || return
	[ -n "$sel" ] || return
	yesno "Delete $MODELS_DIR/$sel ?\n\nThis cannot be undone." && { rm -f "$MODELS_DIR/$sel" && msg "Deleted $sel." || msg "Delete failed (permissions?)."; }
}

# ---------------------------------------------------------------------------
# 6. Advanced -- system actions, each behind a yes/no confirm.
# ---------------------------------------------------------------------------
INSTALLER="${KILN_DIR:-/opt/kiln}/scripts/kiln-install.sh"
advanced_page() {
	while :; do
		sel=$(menu "Advanced" "system actions -- each asks to confirm; some need a reboot" \
			reload "reload the rknpu driver (rmmod + modprobe)" \
			driver "rebuild the rknpu DKMS module + restore wifi" \
			update "update Kiln (git pull + rebuild driver/runtimes; NO kernel change)" \
			kernel "check for a Kiln KERNEL update (may reinstall + reboot)" \
			BACK   "back") || return
		case "$sel" in
			reload)
				yesno "Reload rknpu now?\n\nStop kiln-serve first if it's running (it holds the render node)." || continue
				out=$( { systemctl stop kiln-serve 2>/dev/null; rmmod rknpu && modprobe rknpu; } 2>&1 )
				msg "rknpu reload:\n\n${out:-done (rmmod + modprobe ok)}" ;;
			driver)
				[ -f "$INSTALLER" ] || { msg "installer not found at $INSTALLER"; continue; }
				yesno "Rebuild the rknpu DKMS module and restore wifi now?\n\n(Runs the driver stage; may take a few minutes.)" \
					&& run_installer "KILN_SKIP_KERNEL=1 KILN_SKIP_RUNTIMES=1" ;;
			update)
				[ -f "$INSTALLER" ] || { msg "installer not found at $INSTALLER"; continue; }
				yesno "Update Kiln now?\n\ngit pull + rebuild the driver + runtimes. Does NOT touch the kernel (no reboot)." \
					&& run_installer "" ;;
			kernel)
				[ -f "$INSTALLER" ] || { msg "installer not found at $INSTALLER"; continue; }
				yesno "Check for a newer Kiln KERNEL now?\n\nIf a newer build is published it reinstalls the kernel and the machine REBOOTS to finish. Don't cut power." \
					&& run_installer "KILN_CHECK_KERNEL=1" ;;
			BACK|"") return ;;
		esac
	done
}
# run the installer outside whiptail (its output is long); pause on return.
run_installer() {
	clear 2>/dev/null || true
	echo "=== running: $1 bash $INSTALLER ==="; echo
	env $1 bash "$INSTALLER"; rc=$?
	echo; echo "=== installer exited $rc -- press Enter to return to kiln-config ==="; read -r _
}

# ---------------------------------------------------------------------------
# Main menu
# ---------------------------------------------------------------------------
[ -f "$CONF" ] || msg "No $CONF yet -- run the installer, or I'll create it on first save. Built-in defaults apply until then."
while :; do
	sel=$(menu "Main menu" "Configure Kiln. Pick a section:" \
		1 "Status & Diagnostics  (kiln-doctor)" \
		2 "LLM Settings          ([llm])" \
		3 "Vision Settings       ([vision])" \
		4 "Server                ([server] + kiln-serve)" \
		5 "Models                (list / set / add / remove)" \
		6 "Advanced              (driver / kernel / wifi)" \
		Q "Quit") || break
	case "$sel" in
		1) status_page ;;
		2) llm_page ;;
		3) vision_page ;;
		4) server_page ;;
		5) models_page ;;
		6) advanced_page ;;
		Q|"") break ;;
	esac
done
clear 2>/dev/null || true
